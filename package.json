{
  "name": "linxiv-gui-react",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:sidecar": "pyinstaller linxiv-api.spec --noconfirm && pyinstaller linxiv-cli.spec --noconfirm && pyinstaller linxiv-mcp.spec --noconfirm && python scripts/stage_sidecar.py",
    "build:all": "npm run build:sidecar && npm run tauri build"
  },
  "dependencies": {
