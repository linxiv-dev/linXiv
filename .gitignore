# Environment
.env
.claude
.vscode
__pycache__/
*.py[cod]

# Database
*.db

# arXiv rate-limit timestamp
.arxiv_ratelimit

# Downloaded files, create directories manually if this errors
pdfs/
source/

# Obsidian vault content (keep folder structure)
obsidian_vault/*
!obsidian_vault/.gitkeep

# Package reference docs (downloaded for offline use)
_package_docs/

# OS/Temp_files
.DS_Store
Thumbs.db
features.md
*T.md
pyrightconfig.json
# docs: ignore everything except architecture decision records
# (see gitignore(5): re-include a subtree by un-ignoring the dir, then ignoring its contents, then un-ignoring paths)
docs/*
!docs/adr/
docs/adr/*
!docs/adr/**
# Session state
selected_papers.json
user_settings.json
.venv
# env state
