{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "linXiv",
  "version": "0.1.1",
  "identifier": "com.linxiv.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "linXiv",
        "width": 1280,
        "height": 820,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/linxiv-api",
      "binaries/linxiv",
      "binaries/linxiv-mcp"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
